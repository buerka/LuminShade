<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="28dp" />

        <!-- Permission Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_permission"
            style="@style/SectionLabel" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_permission_state"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                tools:text="已授权" />

            <Button
                android:id="@+id/btn_grant_permission"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/go_to_settings"
                style="@style/BtnSecondary" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_battery_optimize"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/btn_battery_optimize"
            style="@style/BtnSecondary"
            android:layout_marginBottom="24dp" />

        <!-- Mask Controls -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_mask"
            style="@style/SectionLabel" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_add_mask"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/btn_add_mask"
                style="@style/BtnPrimary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_clear_masks"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/btn_clear_masks"
                style="@style/BtnSecondary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_opacity"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seekbar_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="100"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent"
            android:layout_marginBottom="24dp" />

        <Switch
            android:id="@+id/switch_color_match"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_color_match"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_match_color"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_match_color"
                style="@style/BtnSecondary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_replace_color"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_replace_color"
                style="@style/BtnSecondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_pick_match_color"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_pick_match_color"
                style="@style/BtnSecondary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_pick_replace_color"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_pick_replace_color"
                style="@style/BtnSecondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_tolerance_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"
            tools:text="匹配容差：24" />

        <SeekBar
            android:id="@+id/seekbar_tolerance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="120"
            android:progress="24"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_spread_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"
            tools:text="周边改色范围：1 px" />

        <SeekBar
            android:id="@+id/seekbar_spread"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="24"
            android:progress="1"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent"
            android:layout_marginBottom="24dp" />

        <!-- Preset Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/section_preset"
                style="@style/SectionLabel"
                android:layout_marginBottom="0dp" />

            <Button
                android:id="@+id/btn_save_preset"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/btn_save_preset"
                style="@style/BtnSecondary"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btn_new_preset"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/btn_new_preset"
                style="@style/BtnPrimary" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_presets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="24dp" />

        <!-- Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/usage_hint"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
